# Environment: "dev" or "production"
APP_ENV=dev
# Base URL of this backend (leave empty to auto-derive from APP_ENV)
# Examples: http://localhost:8000  |  https://api.myapp.com
SERVER_BASE_URL=

# Frontend URL (used for CORS – set to your deployed frontend URL in production)
# Examples: http://localhost:3000  |  https://myapp.vercel.app
FRONTEND_URL=http://localhost:3000

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=false

# OpenAI
OPENAI_API_KEY=sk-proj-...
SUPERVISOR_LLM=gpt-4o
FAST_LLM=gpt-4o-mini

# LangSmith
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=orthoassist-dev
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com

# Models
HAND_MODEL_PATH=models/hand_yolo.pt
LEG_MODEL_PATH=models/leg_yolo.pt

# Detection thresholds
ROUTER_THRESHOLD=0.70
DETECTOR_SCORE_MIN=0.35
NMS_IOU=0.50
TRIAGE_RED_THRESHOLD=0.80
TRIAGE_AMBER_THRESHOLD=0.60

# Storage
STORAGE_TYPE=local
STORAGE_PATH=./storage
CLOUDINARY_URL=cloudinary://...

# Security
SECRET_KEY=replace_with_a_long_random_secret
PHI_REDACTION_ENABLED=true
MEDICAL_DISCLAIMER_ENABLED=true

# LangGraph
MAX_AGENT_ITERATIONS=10
SESSION_TTL_SECONDS=3600

# MongoDB
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/db_name?retryWrites=true&w=majority
MONGODB_DB_NAME=db_name
